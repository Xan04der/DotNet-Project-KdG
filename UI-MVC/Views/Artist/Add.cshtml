@model Artist

@{
    ViewBag.Title = "Add Artist";
    Layout = "_Layout";
}

<h2>Add an Artist</h2>

<form asp-controller="Artist" asp-action="Add" method="post" class="mb-3">
    <div class="mb-3 row">
        <label class="form-label" asp-for="FirstName">First Name</label>
        <input class="form-label col-5" asp-for="FirstName"/>
        <span class="text-danger" asp-validation-for="FirstName"></span>
    </div>

    <div class="mb-3 row">
        <label class="form-label" asp-for="LastName">Last Name</label>
        <input class="form-label col-5" asp-for="LastName"/>
        <span class="text-danger" asp-validation-for="LastName"></span>
    </div>

    <div class="mb-3 row">
        <label class="form-label" asp-for="Age">Age</label>
        <input class="form-label col-5" asp-for="Age"/>
        <span class="text-danger" asp-validation-for="Age"></span>
    </div>

    <div class="mb-3 row">
        <label class="form-label" asp-for="BirthDate">Date of Birth</label>
        <input class="form-label col-5" asp-for="BirthDate"/>
        <span class="text-danger" asp-validation-for="BirthDate"></span>
    </div>
    
    <div class="mb-3 row">
        <label class="form-label" asp-for="DeathDate">Date of Death (If applicable)</label>
        <input class="form-label col-5" asp-for="DeathDate"/>
        <span class="text-danger" asp-validation-for="DeathDate"></span>
    </div>
    
    <button class="btn btn-primary">Add Artist</button>
</form>